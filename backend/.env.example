# MongoDB Atlas
DATABASE_URL="mongodb+srv://usuario:senha@cluster.mongodb.net/glossflow?retryWrites=true&w=majority"

# Render define PORT automaticamente em produção. Em local, use 3333.
PORT=3333
NODE_ENV="development"

# Obrigatório: use uma chave longa e exclusiva em produção.
JWT_SECRET="troque-por-uma-chave-forte-com-mais-de-32-caracteres"

# Em produção, coloque a URL da Vercel.
# Exemplo: https://glossflow.vercel.app
# Para múltiplas origens, separe por vírgula.
FRONTEND_ORIGIN="http://localhost:5173"

RATE_LIMIT_PER_MINUTE=180
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7

# IA conectada opcional. Sem esta chave, o sistema usa fallback local.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Integrações externas opcionais.
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""
MERCADO_PAGO_ACCESS_TOKEN=""
STRIPE_SECRET_KEY=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
CLOUDINARY_URL=""
SENTRY_DSN=""
META_ACCESS_TOKEN=""
