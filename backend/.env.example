# =============================================================================
# GlossFlow API - ambiente local/produção
# Copie este arquivo para .env e preencha com dados reais.
# Nunca versionar .env com credenciais reais.
# =============================================================================

# Banco MongoDB Atlas
DATABASE_URL="mongodb+srv://usuario:senha@cluster.mongodb.net/glossflow?retryWrites=true&w=majority"

PORT=3333
NODE_ENV="development"
FRONTEND_ORIGIN="http://localhost:5173"

# Segurança
JWT_SECRET="troque-por-uma-chave-forte-com-mais-de-32-caracteres"
RATE_LIMIT_PER_MINUTE=180
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7

# IA - OpenAI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# WhatsApp Cloud API - Meta
# Enquanto estiver vazio, use WHATSAPP_DRY_RUN=true para testar sem envio real.
WHATSAPP_PROVIDER="meta"
WHATSAPP_DRY_RUN="true"
WHATSAPP_API_VERSION="v20.0"
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
# Provider personalizado opcional
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""

# Pagamentos
PAYMENTS_DRY_RUN="true"
MERCADO_PAGO_ACCESS_TOKEN=""
DEFAULT_PAYER_EMAIL="cliente@example.com"
STRIPE_SECRET_KEY=""
STRIPE_PRICE_ID=""
STRIPE_SUCCESS_URL="http://localhost:5173/sucesso"
STRIPE_CANCEL_URL="http://localhost:5173/cancelado"

# Observabilidade
SENTRY_DSN=""
VITE_SENTRY_DSN=""

# Deploy/serviços futuros
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
CLOUDINARY_URL=""
META_ACCESS_TOKEN=""

# Produção / Comercial
PUBLIC_API_URL="http://localhost:3333"
DEFAULT_SALON_ID=""
COMMERCIAL_NOTIFY_WHATSAPP_TO=""
AFFILIATE_COMMISSION_PERCENT=20
TRIAL_DAYS=7
APP_PUBLIC_URL="http://localhost:5173"
