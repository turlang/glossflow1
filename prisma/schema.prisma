datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Salon {
  id           String              @id @default(auto()) @map("_id") @db.ObjectId
  slug         String              @unique
  name         String
  description  String              @default("")
  phone        String
  whatsapp     String              @default("")
  address      String              @default("")
  openingHours String              @default("")
  instagram    String              @default("")
  heroImage    String              @default("")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  users        User[]
  services     Service[]
  professionals Professional[]
  portfolioItems PortfolioItem[]
  appointments Appointment[]
  clients      Client[]
  inventoryProducts InventoryProduct[]
  financialEntries FinancialEntry[]
  commissionRules CommissionRule[]
  loyaltyProgram LoyaltyProgram?
  loyaltyEntries LoyaltyEntry[]
  subscription SalonSubscription?
  whatsappTemplates WhatsAppTemplate[]
  aiSuggestions AiSuggestion[]
  auditLogs AuditLog[]
  lgpdConsents LgpdConsent[]
  backups BackupJob[]
  sessions UserSession[]
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  password  String
  role      String   @default("RECEPTION")
  active    Boolean  @default(true)
  salonId   String   @db.ObjectId
  salon     Salon    @relation(fields: [salonId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sessions  UserSession[]
  auditLogs AuditLog[]

  @@index([salonId])
}

model UserSession {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  userId           String    @db.ObjectId
  salonId          String    @db.ObjectId
  refreshTokenHash String
  userAgent        String    @default("")
  ip               String    @default("")
  revokedAt        DateTime?
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  lastUsedAt       DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id])
  salon            Salon     @relation(fields: [salonId], references: [id])

  @@index([userId])
  @@index([salonId])
  @@index([refreshTokenHash])
}

model Service {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String   @default("")
  price       Float
  durationMin Int
  imageUrl    String   @default("")
  active      Boolean  @default(true)
  salonId     String   @db.ObjectId
  salon       Salon    @relation(fields: [salonId], references: [id])
  appointments Appointment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([salonId])
}

model Professional {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  specialty   String
  bio         String   @default("")
  photoUrl    String   @default("")
  active      Boolean  @default(true)
  salonId     String   @db.ObjectId
  salon       Salon    @relation(fields: [salonId], references: [id])
  appointments Appointment[]
  commissionRules CommissionRule[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([salonId])
}

model PortfolioItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  imageUrl    String
  category    String
  salonId     String   @db.ObjectId
  salon       Salon    @relation(fields: [salonId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([salonId])
}

model Client {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  phone       String
  email       String?
  birthDate   DateTime?
  notes       String   @default("")
  preferences String   @default("")
  salonId     String   @db.ObjectId
  salon       Salon    @relation(fields: [salonId], references: [id])
  appointments Appointment[]
  loyaltyEntries LoyaltyEntry[]
  consents    LgpdConsent[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([salonId])
  @@index([phone])
}

model Appointment {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  clientName     String
  clientPhone    String
  clientEmail    String?
  notes          String   @default("")
  startTime      DateTime
  endTime        DateTime
  status         String   @default("CONFIRMED")
  commissionPaid Boolean  @default(false)
  salonId        String   @db.ObjectId
  salon          Salon    @relation(fields: [salonId], references: [id])
  serviceId      String   @db.ObjectId
  service        Service  @relation(fields: [serviceId], references: [id])
  professionalId String   @db.ObjectId
  professional   Professional @relation(fields: [professionalId], references: [id])
  clientId       String?  @db.ObjectId
  client         Client?  @relation(fields: [clientId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([salonId])
  @@index([professionalId])
  @@index([startTime])
}

model InventoryProduct {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  category        String
  supplier        String   @default("")
  unit            String   @default("un")
  quantity        Int
  minimumQuantity Int
  costPrice       Float
  salePrice       Float?
  imageUrl        String   @default("")
  active          Boolean  @default(true)
  salonId         String   @db.ObjectId
  salon           Salon    @relation(fields: [salonId], references: [id])
  movements       InventoryMovement[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([salonId])
}

model InventoryMovement {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  type      String
  quantity  Int
  reason    String
  productId String   @db.ObjectId
  product   InventoryProduct @relation(fields: [productId], references: [id])
  salonId   String   @db.ObjectId
  createdAt DateTime @default(now())

  @@index([salonId])
  @@index([productId])
}

model FinancialEntry {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  type          String
  category      String
  description   String
  amount        Float
  paymentMethod String?
  referenceDate DateTime @default(now())
  paid          Boolean  @default(true)
  salonId       String   @db.ObjectId
  salon         Salon    @relation(fields: [salonId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([salonId])
}

model CommissionRule {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  professionalId String   @db.ObjectId
  professional   Professional @relation(fields: [professionalId], references: [id])
  percentage     Float
  active         Boolean  @default(true)
  notes          String   @default("")
  salonId        String   @db.ObjectId
  salon          Salon    @relation(fields: [salonId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([salonId])
}

model LoyaltyProgram {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  pointsPerCurrency Float
  rewardDescription String
  active            Boolean  @default(true)
  salonId           String   @unique @db.ObjectId
  salon             Salon    @relation(fields: [salonId], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model LoyaltyEntry {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  clientId  String   @db.ObjectId
  client    Client   @relation(fields: [clientId], references: [id])
  type      String
  points    Int
  reason    String
  salonId   String   @db.ObjectId
  salon     Salon    @relation(fields: [salonId], references: [id])
  createdAt DateTime @default(now())

  @@index([salonId])
}

model SubscriptionPlan {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  price     Float
  maxUsers  Int
  maxSalons Int     @default(1)
  features  String
  active    Boolean @default(true)
  createdAt DateTime @default(now())
  subscriptions SalonSubscription[]
}

model SalonSubscription {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  planId    String   @db.ObjectId
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
  status    String   @default("TRIAL")
  endsAt    DateTime?
  salonId   String   @unique @db.ObjectId
  salon     Salon    @relation(fields: [salonId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WhatsAppTemplate {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  event     String
  message   String
  active    Boolean  @default(true)
  salonId   String   @db.ObjectId
  salon     Salon    @relation(fields: [salonId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([salonId])
}

model AiSuggestion {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  content   String
  category  String   @default("GENERAL")
  priority  String   @default("MEDIUM")
  salonId   String   @db.ObjectId
  salon     Salon    @relation(fields: [salonId], references: [id])
  createdAt DateTime @default(now())

  @@index([salonId])
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  action    String
  resource  String
  resourceId String?
  method    String
  path      String
  ip        String   @default("")
  userAgent String   @default("")
  metadata  Json?
  userId    String?  @db.ObjectId
  user      User?    @relation(fields: [userId], references: [id])
  salonId   String   @db.ObjectId
  salon     Salon    @relation(fields: [salonId], references: [id])
  createdAt DateTime @default(now())

  @@index([salonId])
  @@index([createdAt])
}

model LgpdConsent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  clientId  String?  @db.ObjectId
  client    Client?  @relation(fields: [clientId], references: [id])
  type      String
  granted   Boolean  @default(true)
  evidence  String   @default("")
  salonId   String   @db.ObjectId
  salon     Salon    @relation(fields: [salonId], references: [id])
  createdAt DateTime @default(now())

  @@index([salonId])
}

model BackupJob {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  status    String   @default("COMPLETED")
  kind      String   @default("MANUAL")
  summary   String   @default("")
  salonId   String   @db.ObjectId
  salon     Salon    @relation(fields: [salonId], references: [id])
  createdAt DateTime @default(now())

  @@index([salonId])
}
